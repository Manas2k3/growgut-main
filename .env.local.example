# Alternative 1: Path to JSON file (local development only)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Alternative 2: Full JSON content (required for Vercel)
# FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", ...}'

# Razorpay — Server side only (never expose KEY_SECRET to client)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Razorpay — Public key ID sent to the browser (safe to expose)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
